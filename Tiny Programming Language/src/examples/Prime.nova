// Prime numbers up to 50
function isPrime(n) {
  if (n < 2) {
    return false
  }

  let divisor = 2
  while (divisor * divisor <= n) {
    if (n % divisor == 0) {
      return false
    }
    divisor = divisor + 1
  }

  return true
}

let primes = []
for (let number = 2; number <= 50; number = number + 1) {
  if (isPrime(number)) {
    primes.push(number)
  }
}

print("Primes:", primes)
